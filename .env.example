# =============================================================================
# Supabase (required)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend build-time (Vite) — same values as above for URL + anon key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# API server
# =============================================================================
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated allowed origins for CORS (production).
# Example: https://your-app.vercel.app,https://report-automation-hub.vercel.app
FRONTEND_URL=http://localhost:5173

# =============================================================================
# Frontend / Desktop — API base URL
# =============================================================================
# Leave empty for same-origin /api (local dev proxy or Vercel rewrite).
# Required for desktop builds and when API is hosted on a separate domain.
# VITE_API_URL=https://your-api.railway.app

# Set to "desktop" when building the Electron app installer.
# VITE_APP_TARGET=desktop

# Static asset base path (default /)
BASE_PATH=/

# =============================================================================
# Vercel deployment (optional — set in Vercel project settings)
# =============================================================================
# API_ORIGIN=https://your-api.railway.app

# =============================================================================
# Legacy / optional
# =============================================================================
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
