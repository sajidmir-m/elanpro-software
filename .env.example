# =============================================================================
# Supabase (required)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend build-time (Vite) — same values as above for URL + anon key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# API server (local dev / Render — not needed on Vercel)
# =============================================================================
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Optional CORS allowlist (Vercel auto-adds VERCEL_URL when deployed there)
# FRONTEND_URL=http://localhost:5173

# =============================================================================
# Email reports (Resend) — used by the "Email Report" button on Live Ops
# =============================================================================
# Get a key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
# Resend's shared sandbox sender only delivers to the email address that owns
# the API key. Verify your own domain in Resend and set this to
# "Your Name <reports@yourdomain.com>" once you're ready to send to real users.
RESEND_FROM_EMAIL=Report Automation Hub <onboarding@resend.dev>

# =============================================================================
# Frontend / Desktop — API base URL
# =============================================================================
# Leave empty on Vercel (frontend + API share the same domain /api/*).
# Required for desktop builds only.
# VITE_API_URL=https://your-app.vercel.app

# VITE_APP_TARGET=desktop

BASE_PATH=/
